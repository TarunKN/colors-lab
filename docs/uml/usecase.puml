@startuml usecase

title Colors Web Application - Use Case Diagram

left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "User" as user
actor "Database" as db <<system>>

rectangle "Colors Web Application" {
    usecase "Log In" as UC1
    usecase "Log Out" as UC2
    usecase "Add Color" as UC3
    usecase "Search Colors" as UC4
    usecase "View Color Results" as UC5
    usecase "Hash Password (MD5)" as UC6
    usecase "Save Session Cookie" as UC7
    usecase "Read Session Cookie" as UC8
    usecase "Validate Credentials" as UC9
    usecase "Insert Color into DB" as UC10
    usecase "Query Colors from DB" as UC11
}

user --> UC1
user --> UC2
user --> UC3
user --> UC4

UC1 .> UC6 : <<include>>
UC1 .> UC9 : <<include>>
UC1 .> UC7 : <<include>>

UC3 .> UC8 : <<include>>
UC3 .> UC10 : <<include>>

UC4 .> UC8 : <<include>>
UC4 .> UC11 : <<include>>
UC4 .> UC5 : <<include>>

UC9 --> db
UC10 --> db
UC11 --> db

@enduml

